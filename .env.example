# Local embedded libSQL database
LIBSQL_DATABASE_URL=file:./stress-libsql.db

# Self-hosted libSQL/sqld remote (primary HTTP)
LIBSQL_REMOTE_URL=http://127.0.0.1:18080

# Optional auth token for self-hosted sqld / Turso
LIBSQL_AUTH_TOKEN=

# Embedded client replica path (with LIBSQL_REMOTE_URL)
LIBSQL_REPLICA_PATH=./replica.db

# Offline-synced mode: local file + push/pull with remote (requires REPLICA_PATH + REMOTE_URL)
# LIBSQL_OFFLINE_SYNC=1

# Multi-node sqld replica HTTP (gRPC cluster reader / write-forwarder)
LIBSQL_REPLICA_HTTP_URL=http://127.0.0.1:18081

# --- libSQL engine options (wired into LibsqlEngineOptions) ---

# Multi-tenant namespace header for remote / replica
# LIBSQL_NAMESPACE=tenant-a

# Local AES-256-CBC encryption key (raw string bytes by default)
# LIBSQL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
# LIBSQL_ENCRYPTION_KEY_BASE64=1

# Remote encryption key header (base64)
# LIBSQL_REMOTE_ENCRYPTION_KEY=

# Background sync interval for replica / offline modes (milliseconds)
# LIBSQL_SYNC_INTERVAL_MS=2000

# Replica/offline write visibility + offline push behavior
# LIBSQL_READ_YOUR_WRITES=true
# LIBSQL_REMOTE_WRITES=true

# --- Remote tuning (ProviderTuning) ---
LIBSQL_BUSY_TIMEOUT_MS=5000
LIBSQL_TRANSIENT_RETRIES=4
LIBSQL_RETRY_BASE_DELAY_MS=25

# --- sqld process options (scripts/start-sqld.sh, start-cluster.sh) ---
# SQLD_HTTP_LISTEN_ADDR=127.0.0.1:18080
# SQLD_DB_PATH=./tmp/sqld-data
# SQLD_EXTENSIONS_PATH=./tmp/extensions
# SQLD_ENABLE_BOTTOMLESS_REPLICATION=1
# (bottomless also needs its S3/object-store env vars as documented by libsql-server)
