# Local embedded libSQL database
LIBSQL_DATABASE_URL=file:./stress-libsql.db

# Self-hosted libSQL/sqld remote
LIBSQL_REMOTE_URL=http://127.0.0.1:8080

# Optional auth token for self-hosted sqld
LIBSQL_AUTH_TOKEN=

# Optional local replica path; when set with LIBSQL_REMOTE_URL, use replica mode
LIBSQL_REPLICA_PATH=./replica.db
